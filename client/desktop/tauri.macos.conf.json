{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": {
      "script": "bash scripts/fetch-tmux.sh && npm run dev:vite",
      "cwd": "../.."
    },
    "beforeBuildCommand": {
      "script": "npm run build && bash scripts/fetch-tmux.sh",
      "cwd": "../.."
    }
  },
  "bundle": {
    "externalBin": ["binaries/tmux"],
    "resources": {
      "binaries/tmux-licenses": "tmux-licenses"
    }
  }
}
